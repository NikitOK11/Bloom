msgstr "Stage"

msgid "дата уточняется"
msgstr "date TBD"

msgid "Этапы пока не добавлены."
msgstr "No stages added yet."

msgid "Сезоны пока не добавлены."
msgstr "No editions added yet."

msgid "Командное участие"
msgstr "Team participation"

msgid "Командный трек"
msgstr "Team track"

msgid "Создать команду"
msgstr "Create team"

msgid "Командная поддержка для событий будет развиваться дальше."
msgstr "Team support for events will continue to evolve."

msgid "Войдите"
msgstr "Log in"

msgid "чтобы создать команду."
msgstr "to create a team."

msgid "Открыта"
msgstr "Open"

msgid "Закрыта"
msgstr "Closed"

msgid "К этому событию пока нет привязанных команд."
msgstr "No teams linked to this event yet."

